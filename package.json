{
  "name": "playwright-test-framework",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright JS framework with UI tests for SauceDemo and API tests for Restful Booker",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-tests",
    "test:api": "playwright test --project=api",
    "test:headed": "playwright test --project=ui-tests --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "dotenv": "^16.6.1",
    "ajv": "^8.17.1",
    "eslint": "^9.30.1",
    "@eslint/js": "^9.30.1",
    "globals": "^16.3.0"
  }
}
